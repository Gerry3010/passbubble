#!/usr/bin/env bash

# Advanced Password Generator Utility
# Part of Password Manager Project
# Version: 1.0.0

set -euo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Print functions
print_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
print_success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
print_warning() { echo -e "${YELLOW}[WARNING]${NC} $1"; }
print_error() { echo -e "${RED}[ERROR]${NC} $1" >&2; }

# Show usage
show_usage() {
    cat << 'EOF'
Advanced Password Generator

Usage: pwgen-advanced [OPTIONS]

Options:
    -l, --length LENGTH         Password length (default: 16, min: 8, max: 128)
    -c, --count COUNT           Number of passwords to generate (default: 1)
    -t, --type TYPE             Password type:
                                  strong    - Mixed case, numbers, symbols (default)
                                  alphanum  - Letters and numbers only
                                  numbers   - Numbers only
                                  memorable - Pronounceable passwords
                                  passphrase- Multiple words separated by symbols
    -s, --symbols CHARS         Custom symbol set (default: !@#$%^&*()_+-=[]{}|;:,.<>?)
    -e, --exclude CHARS         Characters to exclude from password
    --no-ambiguous              Exclude ambiguous characters (0, O, l, 1, I)
    --min-upper N               Minimum uppercase letters (default: 1)
    --min-lower N               Minimum lowercase letters (default: 1)
    --min-digits N              Minimum digits (default: 1)
    --min-symbols N             Minimum symbols (default: 1)
    --check                     Check password strength
    -h, --help                  Show this help message

Password Types:
    strong      - Default secure password with mixed characters
    alphanum    - Only letters and numbers (good for systems with symbol restrictions)
    numbers     - Only digits (for PIN codes)
    memorable   - Easier to remember passwords
    passphrase  - Multiple words (e.g., "correct-horse-battery-staple")

Examples:
    pwgen-advanced -l 20 -c 5                    # 5 strong passwords, 20 chars each
    pwgen-advanced -t alphanum -l 12             # Alphanumeric password, 12 chars
    pwgen-advanced -t passphrase                 # Passphrase style password
    pwgen-advanced --no-ambiguous -l 16          # No confusing characters
    pwgen-advanced -s "!@#$" --min-symbols 2     # Custom symbols, min 2 symbols

EOF
}

# Check if required tools are available
check_dependencies() {
    local missing_tools=()
    
    if ! command -v openssl >/dev/null 2>&1; then
        missing_tools+=("openssl")
    fi
    
    if [[ ${#missing_tools[@]} -gt 0 ]]; then
        print_error "Missing required tools: ${missing_tools[*]}"
        print_info "Please install the missing tools and try again"
        exit 1
    fi
}

# Generate random number within range
random_range() {
    local min=$1
    local max=$2
    echo $((min + RANDOM % (max - min + 1)))
}

# Get random character from string
random_char() {
    local chars="$1"
    local pos=$((RANDOM % ${#chars}))
    echo "${chars:$pos:1}"
}

# Check password strength
check_strength() {
    local password="$1"
    local length=${#password}
    local score=0
    local feedback=()
    
    # Length scoring
    if [[ $length -ge 12 ]]; then
        score=$((score + 25))
    elif [[ $length -ge 8 ]]; then
        score=$((score + 15))
    else
        feedback+=("Password is too short (minimum 8 characters)")
    fi
    
    # Character variety scoring
    if [[ "$password" =~ [a-z] ]]; then
        score=$((score + 15))
    else
        feedback+=("Add lowercase letters")
    fi
    
    if [[ "$password" =~ [A-Z] ]]; then
        score=$((score + 15))
    else
        feedback+=("Add uppercase letters")
    fi
    
    if [[ "$password" =~ [0-9] ]]; then
        score=$((score + 15))
    else
        feedback+=("Add numbers")
    fi
    
    if [[ "$password" =~ [^a-zA-Z0-9] ]]; then
        score=$((score + 20))
    else
        feedback+=("Add symbols")
    fi
    
    # Pattern detection penalties
    if [[ "$password" =~ (.)\1{2,} ]]; then
        score=$((score - 10))
        feedback+=("Avoid repeated characters")
    fi
    
    if [[ "$password" =~ (abc|bcd|cde|def|efg|fgh|ghi|hij|ijk|jkl|klm|lmn|mno|nop|opq|pqr|qrs|rst|stu|tuv|uvw|vwx|wxy|xyz) ]] || \
       [[ "$password" =~ (012|123|234|345|456|567|678|789) ]]; then
        score=$((score - 15))
        feedback+=("Avoid sequential characters")
    fi
    
    # Determine strength level
    local level
    if [[ $score -ge 80 ]]; then
        level="${GREEN}Very Strong${NC}"
    elif [[ $score -ge 65 ]]; then
        level="${BLUE}Strong${NC}"
    elif [[ $score -ge 50 ]]; then
        level="${YELLOW}Moderate${NC}"
    elif [[ $score -ge 35 ]]; then
        level="${YELLOW}Weak${NC}"
    else
        level="${RED}Very Weak${NC}"
    fi
    
    echo -e "Password: $password"
    echo -e "Strength: $level (Score: $score/100)"
    echo -e "Length: $length characters"
    
    if [[ ${#feedback[@]} -gt 0 ]]; then
        echo -e "Suggestions:"
        printf ' - %s\n' "${feedback[@]}"
    fi
}

# Generate memorable password
generate_memorable() {
    local length=$1
    local vowels="aeiou"
    local consonants="bcdfghjklmnpqrstvwxyz"
    local password=""
    local use_consonant=true
    
    for ((i=0; i<length; i++)); do
        if $use_consonant; then
            password+=$(random_char "$consonants")
        else
            password+=$(random_char "$vowels")
        fi
        use_consonant=$(!use_consonant)
    done
    
    # Capitalize random positions and add numbers
    local result=""
    for ((i=0; i<${#password}; i++)); do
        local char="${password:$i:1}"
        if [[ $((RANDOM % 4)) -eq 0 ]]; then
            char="${char^^}"  # Uppercase
        fi
        if [[ $((RANDOM % 6)) -eq 0 ]] && [[ $i -gt 0 ]] && [[ $i -lt $((${#password} - 1)) ]]; then
            char+="$((RANDOM % 10))"
        fi
        result+="$char"
    done
    
    echo "${result:0:$length}"
}

# Generate passphrase
generate_passphrase() {
    local word_count=4
    local words=(
        "apple" "banana" "cherry" "dragon" "elephant" "forest" "guitar" "hammer"
        "island" "jungle" "kitchen" "laptop" "mountain" "notebook" "orange" "piano"
        "quiet" "rainbow" "shadow" "table" "umbrella" "valley" "window" "yellow"
        "zebra" "bridge" "castle" "dancer" "engine" "flower" "garden" "helper"
        "iceberg" "journey" "keychain" "library" "melody" "network" "octopus" "penguin"
    )
    
    local separators=("-" "_" "." "!")
    local separator=$(random_char "${separators[*]}")
    local passphrase=""
    
    for ((i=0; i<word_count; i++)); do
        local word_index=$((RANDOM % ${#words[@]}))
        local word="${words[$word_index]}"
        
        # Randomly capitalize
        if [[ $((RANDOM % 2)) -eq 0 ]]; then
            word="${word^}"
        fi
        
        passphrase+="$word"
        if [[ $i -lt $((word_count - 1)) ]]; then
            passphrase+="$separator"
        fi
    done
    
    # Add random number at the end
    passphrase+="$((RANDOM % 100))"
    
    echo "$passphrase"
}

# Generate password based on type
generate_password() {
    local length=$1
    local type=$2
    local symbols=$3
    local exclude=$4
    local no_ambiguous=$5
    local min_upper=$6
    local min_lower=$7
    local min_digits=$8
    local min_symbols=$9
    
    case "$type" in
        "memorable")
            generate_memorable "$length"
            return
            ;;
        "passphrase")
            generate_passphrase
            return
            ;;
        "numbers")
            local chars="0123456789"
            ;;
        "alphanum")
            local chars="abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
            ;;
        "strong"|*)
            local chars="abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789$symbols"
            ;;
    esac
    
    # Remove excluded characters
    if [[ -n "$exclude" ]]; then
        for ((i=0; i<${#exclude}; i++)); do
            local char="${exclude:$i:1}"
            chars="${chars//$char/}"
        done
    fi
    
    # Remove ambiguous characters if requested
    if [[ "$no_ambiguous" == "true" ]]; then
        chars="${chars//0/}"
        chars="${chars//O/}"
        chars="${chars//l/}"
        chars="${chars//1/}"
        chars="${chars//I/}"
    fi
    
    local password=""
    local attempts=0
    local max_attempts=1000
    
    while [[ ${#password} -lt $length ]] && [[ $attempts -lt $max_attempts ]]; do
        password+=$(random_char "$chars")
        attempts=$((attempts + 1))
    done
    
    # Ensure minimum requirements are met for 'strong' type
    if [[ "$type" == "strong" ]] && [[ $length -ge 8 ]]; then
        local upper_chars="ABCDEFGHIJKLMNOPQRSTUVWXYZ"
        local lower_chars="abcdefghijklmnopqrstuvwxyz"
        local digit_chars="0123456789"
        local symbol_chars="$symbols"
        
        # Remove excluded characters from requirement sets
        if [[ -n "$exclude" ]]; then
            for ((i=0; i<${#exclude}; i++)); do
                local char="${exclude:$i:1}"
                upper_chars="${upper_chars//$char/}"
                lower_chars="${lower_chars//$char/}"
                digit_chars="${digit_chars//$char/}"
                symbol_chars="${symbol_chars//$char/}"
            done
        fi
        
        # Apply no-ambiguous filter to requirement sets
        if [[ "$no_ambiguous" == "true" ]]; then
            upper_chars="${upper_chars//O/}"
            upper_chars="${upper_chars//I/}"
            lower_chars="${lower_chars//l/}"
            digit_chars="${digit_chars//0/}"
            digit_chars="${digit_chars//1/}"
        fi
        
        # Ensure minimum character requirements
        local password_array=()
        for ((i=0; i<${#password}; i++)); do
            password_array+=("${password:$i:1}")
        done
        
        # Replace characters to meet minimum requirements
        local pos=0
        
        # Ensure minimum uppercase
        local upper_count=$(echo "$password" | tr -cd "$upper_chars" | wc -c)
        while [[ $upper_count -lt $min_upper ]] && [[ $pos -lt $length ]] && [[ -n "$upper_chars" ]]; do
            password_array[$pos]=$(random_char "$upper_chars")
            pos=$((pos + 1))
            upper_count=$((upper_count + 1))
        done
        
        # Ensure minimum lowercase
        local lower_count=$(echo "$password" | tr -cd "$lower_chars" | wc -c)
        while [[ $lower_count -lt $min_lower ]] && [[ $pos -lt $length ]] && [[ -n "$lower_chars" ]]; do
            password_array[$pos]=$(random_char "$lower_chars")
            pos=$((pos + 1))
            lower_count=$((lower_count + 1))
        done
        
        # Ensure minimum digits
        local digit_count=$(echo "$password" | tr -cd "$digit_chars" | wc -c)
        while [[ $digit_count -lt $min_digits ]] && [[ $pos -lt $length ]] && [[ -n "$digit_chars" ]]; do
            password_array[$pos]=$(random_char "$digit_chars")
            pos=$((pos + 1))
            digit_count=$((digit_count + 1))
        done
        
        # Ensure minimum symbols
        local symbol_count=$(echo "$password" | tr -cd "$symbol_chars" | wc -c)
        while [[ $symbol_count -lt $min_symbols ]] && [[ $pos -lt $length ]] && [[ -n "$symbol_chars" ]]; do
            password_array[$pos]=$(random_char "$symbol_chars")
            pos=$((pos + 1))
            symbol_count=$((symbol_count + 1))
        done
        
        # Shuffle the array to randomize positions
        for ((i=0; i<$length; i++)); do
            local j=$((RANDOM % length))
            local temp="${password_array[$i]}"
            password_array[$i]="${password_array[$j]}"
            password_array[$j]="$temp"
        done
        
        # Reconstruct password
        password=""
        for char in "${password_array[@]}"; do
            password+="$char"
        done
    fi
    
    echo "${password:0:$length}"
}

# Main function
main() {
    # Default values
    local length=16
    local count=1
    local type="strong"
    local symbols="!@#\$%^&*()_+-=[]{}|;:,.<>?"
    local exclude=""
    local no_ambiguous=false
    local min_upper=1
    local min_lower=1
    local min_digits=1
    local min_symbols=1
    local check_strength=false
    
    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            -l|--length)
                length="$2"
                shift 2
                ;;
            -c|--count)
                count="$2"
                shift 2
                ;;
            -t|--type)
                type="$2"
                shift 2
                ;;
            -s|--symbols)
                symbols="$2"
                shift 2
                ;;
            -e|--exclude)
                exclude="$2"
                shift 2
                ;;
            --no-ambiguous)
                no_ambiguous=true
                shift
                ;;
            --min-upper)
                min_upper="$2"
                shift 2
                ;;
            --min-lower)
                min_lower="$2"
                shift 2
                ;;
            --min-digits)
                min_digits="$2"
                shift 2
                ;;
            --min-symbols)
                min_symbols="$2"
                shift 2
                ;;
            --check)
                check_strength=true
                shift
                ;;
            -h|--help)
                show_usage
                exit 0
                ;;
            *)
                print_error "Unknown option: $1"
                show_usage
                exit 1
                ;;
        esac
    done
    
    # Validate inputs
    if ! [[ "$length" =~ ^[0-9]+$ ]] || [[ $length -lt 8 ]] || [[ $length -gt 128 ]]; then
        print_error "Length must be a number between 8 and 128"
        exit 1
    fi
    
    if ! [[ "$count" =~ ^[0-9]+$ ]] || [[ $count -lt 1 ]] || [[ $count -gt 100 ]]; then
        print_error "Count must be a number between 1 and 100"
        exit 1
    fi
    
    if [[ ! "$type" =~ ^(strong|alphanum|numbers|memorable|passphrase)$ ]]; then
        print_error "Invalid password type: $type"
        exit 1
    fi
    
    check_dependencies
    
    # Generate passwords
    for ((i=0; i<count; i++)); do
        local password
        password=$(generate_password "$length" "$type" "$symbols" "$exclude" "$no_ambiguous" \
                                   "$min_upper" "$min_lower" "$min_digits" "$min_symbols")
        
        if [[ "$check_strength" == "true" ]]; then
            check_strength "$password"
            echo
        else
            echo "$password"
        fi
    done
}

main "$@"