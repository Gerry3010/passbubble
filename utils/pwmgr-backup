#!/usr/bin/env bash

# Password Manager Backup and Restore Utility
# Part of Password Manager Project
# Version: 1.0.0

set -euo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Print functions
print_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
print_success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
print_warning() { echo -e "${YELLOW}[WARNING]${NC} $1"; }
print_error() { echo -e "${RED}[ERROR]${NC} $1" >&2; }

# Configuration
BACKUP_DIR="${HOME}/Documents/pwmgr-backups"
BACKUP_PREFIX="pwmgr-backup"

show_usage() {
    cat << 'EOF'
Password Manager Backup & Restore Utility

Usage: pwmgr-backup [COMMAND] [OPTIONS]

Commands:
    backup                      Create a new backup
    restore <backup-file>       Restore from a backup file
    list                        List available backups
    clean                       Clean old backups (keep last 10)
    verify <backup-file>        Verify backup integrity

Options:
    -d, --dir DIRECTORY         Backup directory (default: ~/Documents/pwmgr-backups)
    -e, --encrypt               Encrypt backup with GPG
    -p, --password              Use password encryption instead of GPG
    -v, --verbose               Verbose output
    -h, --help                  Show this help message

Examples:
    pwmgr-backup backup                        # Create backup
    pwmgr-backup backup --encrypt              # Create encrypted backup with GPG
    pwmgr-backup backup --password             # Create password-protected backup
    pwmgr-backup restore backup-2024-01-15.tar.gz
    pwmgr-backup list
    pwmgr-backup clean

EOF
}

# Check dependencies
check_dependencies() {
    local missing=()
    
    if ! command -v secret-tool >/dev/null 2>&1; then
        missing+=("secret-tool (libsecret-tools)")
    fi
    
    if ! command -v tar >/dev/null 2>&1; then
        missing+=("tar")
    fi
    
    if [[ ${#missing[@]} -gt 0 ]]; then
        print_error "Missing required tools: ${missing[*]}"
        exit 1
    fi
}

# Create backup directory
ensure_backup_dir() {
    if [[ ! -d "$BACKUP_DIR" ]]; then
        mkdir -p "$BACKUP_DIR"
        print_info "Created backup directory: $BACKUP_DIR"
    fi
}

# Export all passwords
export_passwords() {
    local temp_dir="$1"
    local export_file="$temp_dir/passwords.json"
    
    print_info "Exporting passwords from keyring..."
    
    # Create JSON header
    echo '{"passwords": [' > "$export_file"
    
    local first=true
    local count=0
    
    # Export passwords using secret-tool
    while IFS= read -r line; do
        if [[ "$line" =~ ^attribute\.service\ =\ (.+)$ ]]; then
            local service="${BASH_REMATCH[1]}"
            local username=""
            local password=""
            local label=""
            
            # Read the next few lines to get username and other attributes
            while IFS= read -r attr_line; do
                if [[ "$attr_line" =~ ^attribute\.username\ =\ (.+)$ ]]; then
                    username="${BASH_REMATCH[1]}"
                elif [[ "$attr_line" =~ ^label\ =\ (.+)$ ]]; then
                    label="${BASH_REMATCH[1]}"
                elif [[ "$attr_line" =~ ^secret\ =\ (.+)$ ]]; then
                    password="${BASH_REMATCH[1]}"
                    break
                elif [[ "$attr_line" == "" ]]; then
                    break
                fi
            done
            
            # Get the password if not found in the dump
            if [[ -z "$password" ]]; then
                if [[ -n "$username" ]]; then
                    password=$(secret-tool lookup service "$service" username "$username" 2>/dev/null || echo "")
                else
                    password=$(secret-tool lookup service "$service" 2>/dev/null || echo "")
                fi
            fi
            
            if [[ -n "$password" ]]; then
                # Add comma if not first entry
                if [[ "$first" != "true" ]]; then
                    echo "," >> "$export_file"
                fi
                first=false
                
                # Escape JSON strings
                service_escaped=$(echo "$service" | sed 's/\\/\\\\/g; s/"/\\"/g')
                username_escaped=$(echo "$username" | sed 's/\\/\\\\/g; s/"/\\"/g')
                password_escaped=$(echo "$password" | sed 's/\\/\\\\/g; s/"/\\"/g')
                label_escaped=$(echo "$label" | sed 's/\\/\\\\/g; s/"/\\"/g')
                
                cat >> "$export_file" << EOF
    {
      "service": "$service_escaped",
      "username": "$username_escaped",
      "password": "$password_escaped",
      "label": "$label_escaped",
      "exported_at": "$(date -Iseconds)"
    }EOF
                count=$((count + 1))
            fi
        fi
    done < <(secret-tool search --all service '' 2>/dev/null || true)
    
    # Close JSON
    echo '' >> "$export_file"
    echo '],' >> "$export_file"
    echo '"metadata": {' >> "$export_file"
    echo "  \"backup_date\": \"$(date -Iseconds)\"," >> "$export_file"
    echo "  \"hostname\": \"$(hostname)\"," >> "$export_file"
    echo "  \"user\": \"$(whoami)\"," >> "$export_file"
    echo "  \"version\": \"1.0.0\"," >> "$export_file"
    echo "  \"password_count\": $count" >> "$export_file"
    echo '}' >> "$export_file"
    echo '}' >> "$export_file"
    
    print_success "Exported $count passwords"
    return $count
}

# Create backup
create_backup() {
    local use_gpg=false
    local use_password=false
    
    # Parse options
    while [[ $# -gt 0 ]]; do
        case $1 in
            -e|--encrypt)
                use_gpg=true
                shift
                ;;
            -p|--password)
                use_password=true
                shift
                ;;
            *)
                shift
                ;;
        esac
    done
    
    ensure_backup_dir
    
    local timestamp=$(date +%Y-%m-%d_%H-%M-%S)
    local backup_name="${BACKUP_PREFIX}-${timestamp}"
    local temp_dir=$(mktemp -d)
    
    print_info "Creating backup: $backup_name"
    
    # Export passwords
    if ! export_passwords "$temp_dir"; then
        print_warning "No passwords found to backup"
    fi
    
    # Create metadata file
    cat > "$temp_dir/metadata.txt" << EOF
Password Manager Backup
Created: $(date)
Hostname: $(hostname)
User: $(whoami)
Backup Type: $(if $use_gpg; then echo "GPG Encrypted"; elif $use_password; then echo "Password Protected"; else echo "Unencrypted"; fi)
EOF
    
    # Create tar archive
    local backup_file="$BACKUP_DIR/${backup_name}.tar"
    
    cd "$temp_dir"
    tar -cf "$backup_file" .
    cd - >/dev/null
    
    # Compress and optionally encrypt
    if $use_gpg; then
        if command -v gpg >/dev/null 2>&1; then
            print_info "Encrypting backup with GPG..."
            gpg --symmetric --cipher-algo AES256 --compress-algo 2 --s2k-mode 3 \
                --s2k-digest-algo SHA512 --s2k-count 65536 \
                --output "${backup_file}.gpg" "$backup_file"
            rm "$backup_file"
            backup_file="${backup_file}.gpg"
            print_success "Backup encrypted with GPG"
        else
            print_error "GPG not available for encryption"
            exit 1
        fi
    elif $use_password; then
        if command -v openssl >/dev/null 2>&1; then
            print_info "Encrypting backup with password..."
            echo -n "Enter encryption password: "
            read -s encrypt_pass
            echo
            openssl enc -aes-256-cbc -salt -pbkdf2 -iter 100000 \
                   -in "$backup_file" -out "${backup_file}.enc" \
                   -pass pass:"$encrypt_pass"
            rm "$backup_file"
            backup_file="${backup_file}.enc"
            print_success "Backup encrypted with password"
        else
            print_error "OpenSSL not available for encryption"
            exit 1
        fi
    else
        # Just compress
        gzip "$backup_file"
        backup_file="${backup_file}.gz"
    fi
    
    # Cleanup temp directory
    rm -rf "$temp_dir"
    
    local size=$(du -h "$backup_file" | cut -f1)
    print_success "Backup created: $(basename "$backup_file") (${size})"
    print_info "Location: $backup_file"
}

# List backups
list_backups() {
    ensure_backup_dir
    
    print_info "Available backups in $BACKUP_DIR:"
    echo
    
    local found=false
    for backup in "$BACKUP_DIR"/${BACKUP_PREFIX}-*.{tar.gz,tar.gpg,tar.enc} 2>/dev/null; do
        if [[ -f "$backup" ]]; then
            found=true
            local size=$(du -h "$backup" | cut -f1)
            local date=$(date -r "$backup" '+%Y-%m-%d %H:%M:%S')
            local name=$(basename "$backup")
            local type="Unknown"
            
            if [[ "$backup" == *.gpg ]]; then
                type="GPG Encrypted"
            elif [[ "$backup" == *.enc ]]; then
                type="Password Protected"
            elif [[ "$backup" == *.gz ]]; then
                type="Compressed"
            fi
            
            printf "%-40s %8s %19s %s\n" "$name" "$size" "$date" "$type"
        fi
    done
    
    if [[ "$found" != "true" ]]; then
        print_warning "No backups found"
    fi
}

# Verify backup
verify_backup() {
    local backup_file="$1"
    
    if [[ ! -f "$backup_file" ]]; then
        print_error "Backup file not found: $backup_file"
        exit 1
    fi
    
    print_info "Verifying backup: $(basename "$backup_file")"
    
    local temp_dir=$(mktemp -d)
    local success=true
    
    # Decrypt/decompress backup
    if [[ "$backup_file" == *.gpg ]]; then
        if ! gpg --decrypt --quiet --batch --output "$temp_dir/backup.tar" "$backup_file" 2>/dev/null; then
            print_error "Failed to decrypt GPG backup (wrong passphrase?)"
            success=false
        fi
    elif [[ "$backup_file" == *.enc ]]; then
        echo -n "Enter decryption password: "
        read -s decrypt_pass
        echo
        if ! openssl enc -d -aes-256-cbc -pbkdf2 -iter 100000 \
             -in "$backup_file" -out "$temp_dir/backup.tar" \
             -pass pass:"$decrypt_pass" 2>/dev/null; then
            print_error "Failed to decrypt password-protected backup (wrong password?)"
            success=false
        fi
    elif [[ "$backup_file" == *.gz ]]; then
        if ! gunzip -c "$backup_file" > "$temp_dir/backup.tar" 2>/dev/null; then
            print_error "Failed to decompress backup"
            success=false
        fi
    else
        cp "$backup_file" "$temp_dir/backup.tar"
    fi
    
    if $success; then
        # Extract and verify content
        cd "$temp_dir"
        if tar -tf backup.tar >/dev/null 2>&1; then
            tar -xf backup.tar
            
            if [[ -f "passwords.json" ]] && [[ -f "metadata.txt" ]]; then
                local password_count
                password_count=$(jq -r '.metadata.password_count // 0' passwords.json 2>/dev/null || echo "0")
                local backup_date
                backup_date=$(jq -r '.metadata.backup_date // "Unknown"' passwords.json 2>/dev/null || echo "Unknown")
                
                print_success "Backup verification passed"
                print_info "Backup date: $backup_date"
                print_info "Password count: $password_count"
                
                if command -v jq >/dev/null 2>&1; then
                    if ! jq empty passwords.json 2>/dev/null; then
                        print_warning "JSON format issues detected in backup"
                    fi
                fi
            else
                print_error "Backup missing required files"
                success=false
            fi
        else
            print_error "Backup archive is corrupted"
            success=false
        fi
        cd - >/dev/null
    fi
    
    rm -rf "$temp_dir"
    
    if $success; then
        print_success "Backup verification completed successfully"
    else
        print_error "Backup verification failed"
        exit 1
    fi
}

# Restore backup
restore_backup() {
    local backup_file="$1"
    
    if [[ ! -f "$backup_file" ]]; then
        print_error "Backup file not found: $backup_file"
        exit 1
    fi
    
    print_warning "This will restore passwords from backup and may overwrite existing entries!"
    echo -n "Do you want to continue? [y/N]: "
    read -r confirm
    
    if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
        print_info "Restore cancelled"
        exit 0
    fi
    
    # First verify the backup
    if ! verify_backup "$backup_file"; then
        print_error "Backup verification failed, aborting restore"
        exit 1
    fi
    
    local temp_dir=$(mktemp -d)
    
    # Decrypt/decompress backup
    print_info "Extracting backup..."
    if [[ "$backup_file" == *.gpg ]]; then
        gpg --decrypt --quiet --output "$temp_dir/backup.tar" "$backup_file"
    elif [[ "$backup_file" == *.enc ]]; then
        echo -n "Enter decryption password: "
        read -s decrypt_pass
        echo
        openssl enc -d -aes-256-cbc -pbkdf2 -iter 100000 \
               -in "$backup_file" -out "$temp_dir/backup.tar" \
               -pass pass:"$decrypt_pass"
    elif [[ "$backup_file" == *.gz ]]; then
        gunzip -c "$backup_file" > "$temp_dir/backup.tar"
    else
        cp "$backup_file" "$temp_dir/backup.tar"
    fi
    
    cd "$temp_dir"
    tar -xf backup.tar
    
    if [[ -f "passwords.json" ]]; then
        print_info "Restoring passwords to keyring..."
        
        local count=0
        local errors=0
        
        # Parse JSON and restore passwords
        while IFS= read -r entry; do
            local service username password label
            service=$(echo "$entry" | jq -r '.service // empty')
            username=$(echo "$entry" | jq -r '.username // empty')
            password=$(echo "$entry" | jq -r '.password // empty')
            label=$(echo "$entry" | jq -r '.label // empty')
            
            if [[ -n "$service" ]] && [[ -n "$password" ]]; then
                local attributes="service $service"
                if [[ -n "$username" ]]; then
                    attributes="$attributes username $username"
                fi
                
                local store_label="$label"
                if [[ -z "$store_label" ]]; then
                    store_label="Password for $service${username:+ ($username)}"
                fi
                
                if echo "$password" | secret-tool store --label="$store_label" $attributes 2>/dev/null; then
                    count=$((count + 1))
                    print_info "Restored: $service${username:+ ($username)}"
                else
                    errors=$((errors + 1))
                    print_error "Failed to restore: $service${username:+ ($username)}"
                fi
            fi
        done < <(jq -c '.passwords[]' passwords.json 2>/dev/null || echo '{}')
        
        cd - >/dev/null
        rm -rf "$temp_dir"
        
        print_success "Restore completed: $count passwords restored"
        if [[ $errors -gt 0 ]]; then
            print_warning "$errors passwords failed to restore"
        fi
    else
        print_error "No passwords.json found in backup"
        exit 1
    fi
}

# Clean old backups
clean_backups() {
    ensure_backup_dir
    
    print_info "Cleaning old backups (keeping last 10)..."
    
    local backups=()
    while IFS= read -r -d '' backup; do
        backups+=("$backup")
    done < <(find "$BACKUP_DIR" -name "${BACKUP_PREFIX}-*" -type f -print0 | sort -z)
    
    local total=${#backups[@]}
    local keep=10
    
    if [[ $total -le $keep ]]; then
        print_info "Only $total backups found, nothing to clean"
        return
    fi
    
    local to_remove=$((total - keep))
    print_info "Removing $to_remove old backups..."
    
    for ((i=0; i<to_remove; i++)); do
        local backup="${backups[$i]}"
        rm "$backup"
        print_info "Removed: $(basename "$backup")"
    done
    
    print_success "Cleaned $to_remove old backups"
}

# Main function
main() {
    local verbose=false
    
    # Parse global options
    while [[ $# -gt 0 ]]; do
        case $1 in
            -d|--dir)
                BACKUP_DIR="$2"
                shift 2
                ;;
            -v|--verbose)
                verbose=true
                shift
                ;;
            -h|--help)
                show_usage
                exit 0
                ;;
            *)
                break
                ;;
        esac
    done
    
    if [[ $# -eq 0 ]]; then
        show_usage
        exit 1
    fi
    
    check_dependencies
    
    case $1 in
        backup)
            shift
            create_backup "$@"
            ;;
        restore)
            if [[ $# -lt 2 ]]; then
                print_error "Backup file required for restore command"
                exit 1
            fi
            restore_backup "$2"
            ;;
        list)
            list_backups
            ;;
        verify)
            if [[ $# -lt 2 ]]; then
                print_error "Backup file required for verify command"
                exit 1
            fi
            verify_backup "$2"
            ;;
        clean)
            clean_backups
            ;;
        *)
            print_error "Unknown command: $1"
            show_usage
            exit 1
            ;;
    esac
}

main "$@"