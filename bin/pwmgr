#!/usr/bin/env bash

# Password Manager with Keychain Support
# Uses GNOME Keyring as backend storage
# Author: Generated for Gerry
# Version: 1.0.0

set -euo pipefail

# Configuration
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
CONFIG_DIR="$PROJECT_DIR/config"
CONFIG_FILE="$CONFIG_DIR/pwmgr.conf"

# Default configuration
DEFAULT_KEYRING="login"
DEFAULT_SCHEMA="org.freedesktop.Secret.Generic"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Load configuration
load_config() {
    if [[ -f "$CONFIG_FILE" ]]; then
        source "$CONFIG_FILE"
    fi
}

# Print colored output
print_info() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1" >&2
}

# Show usage
show_usage() {
    cat << EOF
Password Manager - Keychain Edition

Usage: $(basename "$0") [COMMAND] [OPTIONS]

Commands:
    add <service> [username]    Add a new password entry
    get <service> [username]    Retrieve a password
    list                        List all stored services
    update <service> [username] Update an existing password
    delete <service> [username] Delete a password entry
    generate [length]           Generate a random password
    search <pattern>            Search for services matching pattern
    export                      Export passwords (encrypted backup)
    import <file>               Import passwords from backup
    config                      Show current configuration
    init                        Initialize the password manager

Options:
    -h, --help                  Show this help message
    -v, --verbose               Verbose output
    -q, --quiet                 Quiet mode (minimal output)
    --version                   Show version information

Examples:
    $(basename "$0") add gmail john.doe@gmail.com
    $(basename "$0") get gmail
    $(basename "$0") generate 16
    $(basename "$0") search bank

EOF
}

# Initialize password manager
init_pwmgr() {
    print_info "Initializing Password Manager..."
    
    # Create config directory if it doesn't exist
    mkdir -p "$CONFIG_DIR"
    
    # Create default configuration if it doesn't exist
    if [[ ! -f "$CONFIG_FILE" ]]; then
        cat > "$CONFIG_FILE" << EOF
# Password Manager Configuration
DEFAULT_KEYRING="login"
DEFAULT_SCHEMA="org.freedesktop.Secret.Generic"
DEFAULT_PASSWORD_LENGTH=16
BACKUP_LOCATION="\$HOME/Documents/pwmgr-backups"
EOF
        print_success "Configuration file created at $CONFIG_FILE"
    fi
    
    # Test keyring access
    if command -v secret-tool >/dev/null 2>&1; then
        print_success "GNOME Keyring (secret-tool) is available"
    else
        print_error "secret-tool is not available. Please install libsecret-tools package."
        exit 1
    fi
    
    print_success "Password Manager initialized successfully!"
}

# Generate a random password
generate_password() {
    local length=${1:-16}
    
    if ! [[ "$length" =~ ^[0-9]+$ ]] || [ "$length" -lt 8 ] || [ "$length" -gt 128 ]; then
        print_error "Password length must be a number between 8 and 128"
        exit 1
    fi
    
    # Generate password with mixed characters
    local password
    password=$(openssl rand -base64 $((length * 3 / 4)) | tr -d "=+/" | cut -c1-${length})
    
    echo "$password"
}

# Store password in keyring
store_password() {
    local service="$1"
    local username="${2:-}"
    local password="$3"
    
    local attributes="service $service"
    if [[ -n "$username" ]]; then
        attributes="$attributes username $username"
    fi
    
    echo "$password" | secret-tool store --label="Password for $service${username:+ ($username)}" $attributes
}

# Retrieve password from keyring
get_password() {
    local service="$1"
    local username="${2:-}"
    
    local attributes="service $service"
    if [[ -n "$username" ]]; then
        attributes="$attributes username $username"
    fi
    
    secret-tool lookup $attributes 2>/dev/null
}

# Add a new password
add_password() {
    local service="$1"
    local username="${2:-}"
    
    # Check if password already exists
    if get_password "$service" "$username" >/dev/null 2>&1; then
        print_warning "Password for $service${username:+ ($username)} already exists. Use 'update' command to modify it."
        exit 1
    fi
    
    # Get password from user
    local password
    echo -n "Enter password for $service${username:+ ($username)} (leave empty to generate): "
    read -s password
    echo
    
    if [[ -z "$password" ]]; then
        password=$(generate_password)
        print_info "Generated password: $password"
    fi
    
    store_password "$service" "$username" "$password"
    print_success "Password stored for $service${username:+ ($username)}"
}

# Update existing password
update_password() {
    local service="$1"
    local username="${2:-}"
    
    # Check if password exists
    if ! get_password "$service" "$username" >/dev/null 2>&1; then
        print_error "No password found for $service${username:+ ($username)}. Use 'add' command to create it."
        exit 1
    fi
    
    # Get new password from user
    local password
    echo -n "Enter new password for $service${username:+ ($username)} (leave empty to generate): "
    read -s password
    echo
    
    if [[ -z "$password" ]]; then
        password=$(generate_password)
        print_info "Generated password: $password"
    fi
    
    store_password "$service" "$username" "$password"
    print_success "Password updated for $service${username:+ ($username)}"
}

# Delete password
delete_password() {
    local service="$1"
    local username="${2:-}"
    
    local attributes="service $service"
    if [[ -n "$username" ]]; then
        attributes="$attributes username $username"
    fi
    
    if ! get_password "$service" "$username" >/dev/null 2>&1; then
        print_error "No password found for $service${username:+ ($username)}"
        exit 1
    fi
    
    echo -n "Are you sure you want to delete the password for $service${username:+ ($username)}? [y/N]: "
    read -r confirmation
    
    if [[ "$confirmation" =~ ^[Yy]$ ]]; then
        secret-tool clear $attributes
        print_success "Password deleted for $service${username:+ ($username)}"
    else
        print_info "Operation cancelled"
    fi
}

# List all stored passwords
list_passwords() {
    print_info "Stored password entries:"
    echo
    
    # Use a Python script to properly enumerate entries with service attribute
    python3 -c "
import subprocess
import sys
import re

# Get all keyring entries
try:
    result = subprocess.run(['busctl', '--user', 'call', 
                           'org.freedesktop.secrets', 
                           '/org/freedesktop/secrets/collection/login',
                           'org.freedesktop.Secret.Collection',
                           'SearchItems', 'a{ss}', '0'], 
                          capture_output=True, text=True)
    if result.returncode != 0:
        sys.exit(1)
        
    # Extract item paths
    paths = re.findall(r'/org/freedesktop/secrets/collection/login/[0-9]+', result.stdout)
    
    services = []
    for path in paths:
        # Get attributes for each item
        attr_result = subprocess.run(['busctl', '--user', 'call',
                                    'org.freedesktop.secrets', path,
                                    'org.freedesktop.DBus.Properties', 'Get',
                                    'ss', 'org.freedesktop.Secret.Item', 'Attributes'],
                                   capture_output=True, text=True)
        if attr_result.returncode == 0:
            attrs = attr_result.stdout
            # Look for service attribute
            service_match = re.search(r'\"service\" \"([^\"]+)\"', attrs)
            if service_match:
                service = service_match.group(1)
                username_match = re.search(r'\"username\" \"([^\"]+)\"', attrs)
                if username_match:
                    username = username_match.group(1)
                    services.append(f'{service} ({username})')
                else:
                    services.append(service)
    
    # Sort and print unique services
    for service in sorted(set(services)):
        print(service)
        
    # Exit with 1 if no services found to indicate to shell script
    sys.exit(0 if services else 1)
except Exception as e:
    sys.exit(1)
" 2>/dev/null
    
    # Check the exit code from Python script
    if [[ $? -ne 0 ]]; then
        print_info "No passwords stored with this password manager yet. Use 'add' command to store your first password."
    fi
}

# Search for passwords
search_passwords() {
    local pattern="$1"
    
    print_info "Searching for entries matching: $pattern"
    echo
    
    secret-tool search --all service '' 2>/dev/null | grep -E '^attribute\.(service|username)' | \
    awk -F' = ' '
    /attribute\.service/ { service = $2 }
    /attribute\.username/ { username = $2; entry = service " (" username ")"; service = ""; username = "" }
    END { if (service != "") entry = service }
    { if (entry != "" && (tolower(entry) ~ tolower("'"$pattern"'"))) print entry; entry = "" }
    ' | sort -u
}

# Show configuration
show_config() {
    print_info "Password Manager Configuration:"
    echo
    load_config
    echo "Configuration file: $CONFIG_FILE"
    echo "Default keyring: ${DEFAULT_KEYRING:-login}"
    echo "Default schema: ${DEFAULT_SCHEMA:-org.freedesktop.Secret.Generic}"
    echo "Default password length: ${DEFAULT_PASSWORD_LENGTH:-16}"
    echo "Backup location: ${BACKUP_LOCATION:-$HOME/Documents/pwmgr-backups}"
    echo
    print_info "Keyring status:"
    if systemctl --user is-active gnome-keyring-daemon.service >/dev/null 2>&1; then
        print_success "GNOME Keyring daemon is running"
    else
        print_warning "GNOME Keyring daemon status unknown"
    fi
}

# Main function
main() {
    load_config
    
    # Parse command line arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            -h|--help)
                show_usage
                exit 0
                ;;
            --version)
                echo "Password Manager v1.0.0"
                exit 0
                ;;
            -v|--verbose)
                set -x
                shift
                ;;
            -q|--quiet)
                exec >/dev/null
                shift
                ;;
            init)
                init_pwmgr
                exit 0
                ;;
            add)
                shift
                if [[ $# -lt 1 ]]; then
                    print_error "Service name is required for 'add' command"
                    exit 1
                fi
                add_password "$1" "${2:-}"
                exit 0
                ;;
            get)
                shift
                if [[ $# -lt 1 ]]; then
                    print_error "Service name is required for 'get' command"
                    exit 1
                fi
                password=$(get_password "$1" "${2:-}")
                if [[ -n "$password" ]]; then
                    echo "$password"
                else
                    print_error "No password found for $1${2:+ ($2)}"
                    exit 1
                fi
                exit 0
                ;;
            update)
                shift
                if [[ $# -lt 1 ]]; then
                    print_error "Service name is required for 'update' command"
                    exit 1
                fi
                update_password "$1" "${2:-}"
                exit 0
                ;;
            delete)
                shift
                if [[ $# -lt 1 ]]; then
                    print_error "Service name is required for 'delete' command"
                    exit 1
                fi
                delete_password "$1" "${2:-}"
                exit 0
                ;;
            list)
                list_passwords
                exit 0
                ;;
            search)
                shift
                if [[ $# -lt 1 ]]; then
                    print_error "Search pattern is required for 'search' command"
                    exit 1
                fi
                search_passwords "$1"
                exit 0
                ;;
            generate)
                shift
                generate_password "${1:-16}"
                exit 0
                ;;
            config)
                show_config
                exit 0
                ;;
            *)
                print_error "Unknown command: $1"
                echo
                show_usage
                exit 1
                ;;
        esac
    done
    
    # If no arguments provided, show usage
    show_usage
}

# Run main function with all arguments
main "$@"