# Password Manager Configuration File
# Copy this file to pwmgr.conf and customize as needed

# Keyring settings
DEFAULT_KEYRING="login"
DEFAULT_SCHEMA="org.freedesktop.Secret.Generic"

# Password generation settings
DEFAULT_PASSWORD_LENGTH=16
MIN_PASSWORD_LENGTH=8
MAX_PASSWORD_LENGTH=128

# Default character sets for password generation
DEFAULT_SYMBOLS="!@#$%^&*()_+-=[]{}|;:,.<>?"
EXCLUDE_AMBIGUOUS_CHARS=false  # Set to true to exclude 0, O, l, 1, I

# Backup settings
BACKUP_LOCATION="$HOME/Documents/pwmgr-backups"
MAX_BACKUP_COUNT=10  # Number of backups to keep
AUTO_BACKUP=false    # Set to true to create automatic backups

# Security settings
REQUIRE_CONFIRMATION_FOR_DELETE=true
CLIPBOARD_TIMEOUT=30  # Seconds to keep password in clipboard (0 = forever)
SHOW_GENERATED_PASSWORDS=true  # Show generated passwords on screen

# Display settings
USE_COLORS=true
VERBOSE_OUTPUT=false
QUIET_MODE=false

# Integration settings
ENABLE_BROWSER_INTEGRATION=false
BROWSER_INTEGRATION_PORT=8080

# Export settings
DEFAULT_EXPORT_FORMAT="json"  # json, csv, xml
ENCRYPT_EXPORTS_BY_DEFAULT=true

# Logging (for debugging)
ENABLE_LOGGING=false
LOG_LEVEL="INFO"  # DEBUG, INFO, WARNING, ERROR
LOG_FILE="$HOME/.local/share/pwmgr/pwmgr.log"