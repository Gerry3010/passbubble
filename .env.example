# Database
POSTGRES_PASSWORD=change_me_strong_password

# Redis
REDIS_PASSWORD=change_me_redis_password

# JWT signing secret (min 64 chars random string)
JWT_SECRET=change_me_generate_with_openssl_rand_base64_64

# Server
SERVER_PORT=8765
ENVIRONMENT=development

# First admin user email (set before first docker compose up)
ADMIN_EMAIL=admin@example.com

# Email verification
# In the dev stack (make up) Mailpit is pre-wired — no changes needed here.
# Override APP_BASE_URL if the server runs on a different port or hostname.
APP_BASE_URL=http://localhost:8765
# Mailpit web UI: http://localhost:8025

# Production only (Caddy TLS)
DOMAIN=pwmgr.example.com
CADDY_EMAIL=admin@example.com
